<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="schema-011-create-audit-events" author="authsphere">
        <createTable tableName="audit_events">
            <column name="id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_audit_events" nullable="false"/>
            </column>
            <column name="event_type" type="VARCHAR(80)">
                <constraints nullable="false"/>
            </column>
            <column name="outcome" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>
            <column name="severity" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>
            <column name="actor_user_id" type="UUID"/>
            <column name="actor_email" type="VARCHAR(320)"/>
            <column name="target_type" type="VARCHAR(64)"/>
            <column name="target_id" type="VARCHAR(128)"/>
            <column name="action" type="VARCHAR(120)"/>
            <column name="resource" type="VARCHAR(120)"/>
            <column name="ip_address" type="VARCHAR(64)"/>
            <column name="user_agent" type="VARCHAR(255)"/>
            <column name="correlation_id" type="VARCHAR(100)"/>
            <column name="details_json" type="VARCHAR(4000)"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="audit_events" indexName="idx_audit_events_created_at">
            <column name="created_at"/>
        </createIndex>

        <createIndex tableName="audit_events" indexName="idx_audit_events_event_type">
            <column name="event_type"/>
        </createIndex>

        <createIndex tableName="audit_events" indexName="idx_audit_events_actor_user_id">
            <column name="actor_user_id"/>
        </createIndex>

        <createIndex tableName="audit_events" indexName="idx_audit_events_outcome">
            <column name="outcome"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>


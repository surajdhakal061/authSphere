    <changeSet id="seed-011-admin-user" author="authsphere">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM app_users WHERE email = 'admin@authsphere.local'
            </sqlCheck>
        </preConditions>

        <insert tableName="app_users">
            <column name="id" value="11111111-1111-1111-1111-111111111111"/>
            <column name="email" value="admin@authsphere.local"/>
            <column name="password_hash" value="$2a$10$b2KrYvUfJBFw3EBFErcV2O6Alvv7Bo/0T72/OJMla.BqPin9wK9rG"/>
            <column name="status" value="ACTIVE"/>
            <column name="email_verified" valueBoolean="true"/>
            <column name="failed_login_count" valueNumeric="0"/>
            <column name="token_version" valueNumeric="1"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>
    </changeSet>


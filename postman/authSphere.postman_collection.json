    {
      "name": "Biometric",
      "item": [
        {
          "name": "Register Options",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Device-Name", "value": "Postman Biometric Device" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\",\n  \"credentialName\": \"MacBook Touch ID\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/biometric/register/options"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code < 400) {",
                  "  const data = pm.response.json();",
                  "  if (data.challengeId) pm.collectionVariables.set('challengeId', data.challengeId);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Register Verify",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\",\n  \"challengeId\": \"{{challengeId}}\",\n  \"credentialId\": \"{{credentialId}}\",\n  \"publicKey\": \"sample-public-key\",\n  \"credentialName\": \"MacBook Touch ID\",\n  \"clientProof\": \"sample-client-proof\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/biometric/register/verify"
          }
        },
        {
          "name": "Login Options",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Device-Name", "value": "Postman Biometric Device" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/biometric/login/options"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code < 400) {",
                  "  const data = pm.response.json();",
                  "  if (data.challengeId) pm.collectionVariables.set('challengeId', data.challengeId);",
                  "  if (Array.isArray(data.credentialIds) && data.credentialIds.length > 0) {",
                  "    pm.collectionVariables.set('credentialId', data.credentialIds[0]);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Verify",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Device-Name", "value": "Postman Biometric Device" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"challengeId\": \"{{challengeId}}\",\n  \"credentialId\": \"{{credentialId}}\",\n  \"clientProof\": \"sample-client-proof\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/biometric/login/verify"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code < 400) {",
                  "  const data = pm.response.json();",
                  "  if (data.accessToken) pm.collectionVariables.set('accessToken', data.accessToken);",
                  "  if (data.refreshToken) pm.collectionVariables.set('refreshToken', data.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List Credentials",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Refresh-Token", "value": "{{refreshToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/auth/biometric/credentials"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code < 400) {",
                  "  const data = pm.response.json();",
                  "  if (Array.isArray(data) && data.length > 0) {",
                  "    if (data[0].id) pm.collectionVariables.set('credentialRecordId', data[0].id);",
                  "    if (data[0].credentialId) pm.collectionVariables.set('credentialId', data[0].credentialId);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Revoke Credential",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "X-Refresh-Token", "value": "{{refreshToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/auth/biometric/credentials/{{credentialRecordId}}"
          }
        }
      ]
    },

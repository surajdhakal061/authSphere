{
  "info": {
    "name": "authSphere API",
    "description": "Postman collection for AuthController and AuthorizationController endpoints. NOTE: Email verification is REQUIRED before login. After register, verify email before attempting login.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "f7f791f9-8f93-4ed7-8fcf-2aa5261f1a5d"
  },
  "item": [
    {
      "name": "Auth Core",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Device-Name", "value": "Postman Desktop" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"confirmPassword\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Device-Name", "value": "Postman Desktop" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code < 400) {",
                  "  const data = pm.response.json();",
                  "  if (data.accessToken) pm.collectionVariables.set('accessToken', data.accessToken);",
                  "  if (data.refreshToken) pm.collectionVariables.set('refreshToken', data.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/refresh"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code < 400) {",
                  "  const data = pm.response.json();",
                  "  if (data.accessToken) pm.collectionVariables.set('accessToken', data.accessToken);",
                  "  if (data.refreshToken) pm.collectionVariables.set('refreshToken', data.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/logout"
          }
        },
        {
          "name": "Logout All",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/logout-all"
          }
        }
      ]
    },
    {
      "name": "Sessions",
      "item": [
        {
          "name": "List Sessions (GET + Header)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Refresh-Token", "value": "{{refreshToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/auth/sessions"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code < 400) {",
                  "  const data = pm.response.json();",
                  "  if (Array.isArray(data) && data.length > 0 && data[0].sessionId) {",
                  "    pm.collectionVariables.set('sessionId', data[0].sessionId);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List Sessions (POST + Body)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/sessions"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code < 400) {",
                  "  const data = pm.response.json();",
                  "  if (Array.isArray(data) && data.length > 0 && data[0].sessionId) {",
                  "    pm.collectionVariables.set('sessionId', data[0].sessionId);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Revoke Session (POST)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\",\n  \"sessionId\": \"{{sessionId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/sessions/revoke"
          }
        },
        {
          "name": "Revoke Session (DELETE)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "X-Refresh-Token", "value": "{{refreshToken}}" }
            ],
            "url": "{{baseUrl}}/api/v1/auth/sessions/{{sessionId}}"
          }
        }
      ]
    },
    {
      "name": "Password and Email",
      "item": [
